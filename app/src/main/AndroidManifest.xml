<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network: version manifest, Fabric/Forge APIs, update checker -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Storage: game files, JRE extraction, logs -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Vibration for controller haptics -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Microphone: Simple Voice Chat mod support (optional, runtime-requested) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Foreground service: keep game process alive -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Wake lock: prevent screen from sleeping during game -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher_droidbridge"
        android:roundIcon="@mipmap/ic_launcher_droidbridge_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DroidBridge"
        android:requestLegacyExternalStorage="true"
        android:hardwareAccelerated="true"
        android:largeHeap="true">

        <!-- Splash / Entry point -->
        <activity
            android:name=".SplashActivity"
            android:theme="@style/Theme.DroidBridge.Splash"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main launcher activity (instance list + game launch) -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize"
            android:windowSoftInputMode="adjustResize" />

        <!-- Settings -->
        <activity
            android:name=".LauncherSettingsActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize" />

        <!-- Error reporter -->
        <activity
            android:name=".ErrorActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize" />

        <!-- File provider for sharing logs -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
