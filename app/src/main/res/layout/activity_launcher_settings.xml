<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Top toolbar row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <ImageButton
            android:id="@+id/button_settings_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_downward_24"
            android:contentDescription="@string/settings_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:paddingStart="4dp" />

    </LinearLayout>

    <!-- Section tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/settings_section_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="scrollable"
        app:tabGravity="start" />

    <!-- Scrollable content -->
    <ScrollView
        android:id="@+id/settings_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ══ ACCOUNT section ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/card_account_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Account status row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:id="@+id/image_player_head"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_player_head_placeholder"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/text_account_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="12dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                </LinearLayout>

                <!-- Sign-in / sign-out buttons -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_sign_in"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sign_in_microsoft" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_sign_out"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/sign_out"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_manage_offline_accounts"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/manage_offline_accounts" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_use_microsoft_account"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/use_microsoft_account"
                    android:visibility="gone" />

                <!-- Skin section -->
                <TextView
                    android:id="@+id/text_skin_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_refresh_microsoft_skin"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/button_refresh_skin"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_change_microsoft_skin"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/button_change_microsoft_skin"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ══ RENDERER section ════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/card_renderer_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/spinner_renderer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:id="@+id/layout_vulkan_driver_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Spinner
                        android:id="@+id/spinner_vulkan_driver"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/text_vulkan_driver_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                </LinearLayout>

                <TextView
                    android:id="@+id/text_renderer_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

                <TextView
                    android:id="@+id/text_renderer_plugin_config"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:visibility="gone" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_use_system_vulkan_driver"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/renderer_use_system_vulkan" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_use_open_gl_for_26_plus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/renderer_opengl_for_26_plus" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_import_renderer_plugin"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/renderer_import_plugin" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_grant_renderer_storage_access"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/renderer_grant_storage" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_clear_renderer_plugin_cache"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/renderer_clear_cache" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_refresh_renderers"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/renderer_refresh" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_use_native_surface"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Use native SurfaceView (LTW)" />

            </LinearLayout>

            <!-- ══ CONTROLLER section ══════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/card_controller_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/layout_controller_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_touch_controls_enabled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Touch controls enabled" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_minecraft_touch_gestures"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Minecraft touch gestures" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_double_tap_to_drop"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Double-tap to drop item" />

                    <TextView
                        android:id="@+id/text_double_tap_to_drop_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceLabelSmall" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_avoid_rounded_corners"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Avoid rounded corners" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_force_sdl_controller_bridge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Force SDL controller bridge" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_manage_touch_controls"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Manage touch controls" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_edit_built_in_controller"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Edit built-in controller mapping" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══ LAUNCHER section ════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/card_launcher_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- RAM slider -->
                <SeekBar
                    android:id="@+id/slider_allocated_ram"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="28" />

                <TextView
                    android:id="@+id/text_allocated_ram"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

                <TextView
                    android:id="@+id/text_available_ram_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceLabelSmall" />

                <SeekBar
                    android:id="@+id/slider_game_resolution_scale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="200" />

                <TextView
                    android:id="@+id/text_game_resolution_scale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_force_fullscreen_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Force fullscreen mode" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_show_shared_installs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_show_shared_installs" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_remove_inherited_vanilla"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_remove_inherited_vanilla" />

                <TextView
                    android:id="@+id/text_folder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

                <CheckBox
                    android:id="@+id/check_keep_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_keep_logs" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_show_in_game_settings_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_show_in_game_settings_button" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_show_game_log_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_show_game_log_overlay" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_share_latest_log"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_share_latest_log" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_install_notifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_install_notifications" />

                <TextView
                    android:id="@+id/text_install_notifications_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceLabelSmall" />

            </LinearLayout>

            <!-- ══ INSTANCE section ════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/card_instance_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <!-- Populated dynamically -->
            </LinearLayout>

            <!-- ══ LEGAL / PRIVACY section ════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/card_privacy_policy_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_open_minecraft_eula"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/legal_minecraft_eula" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_open_privacy_policy"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/legal_privacy_policy" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_open_droid_bridge_terms"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/legal_droidbridge_terms" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_open_droid_bridge_license"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/legal_droidbridge_license" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_simple_voice_chat_microphone_permission"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/simple_voice_chat_microphone_permission" />

                <TextView
                    android:id="@+id/text_simple_voice_chat_microphone_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceLabelSmall" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
